# This is Git's per-user configuration file.
[user]
  signingkey = /Users/estcontreras/.ssh/id_ed25519_melisource.pub
	name = esteam
	email = esteban.econtreras@mercadolibre.cl
[init]
	defaultBranch = main
[url "git@github.com:"]
	insteadOf = git://github.com/
	insteadOf = https://github.com//
	insteadOf = https://github.com/
[url "git@github.com-emu:melisource/"]
	insteadOf = https://github.com/melisource/
	insteadOf = git@github.com:melisource/
[url "ssh://git@github.com/"]
    insteadOf = https://github.com/

[gpg]
  format = ssh

[commit]
  gpgsign = true
